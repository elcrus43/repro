# ═══════════════════════════════════════════════════════════════
# .env.example — шаблон переменных окружения
#
# ❗ НИКОГДА не коммитьте .env в репозиторий!
# ❗ Этот файл (.env.example) коммитить МОЖНО — в нём нет реальных ключей.
#
# Использование:
#   cp .env.example .env
#   Затем заполните реальными значениями из:
#     - Supabase: https://app.supabase.com → Project Settings → API
#     - Google: https://console.cloud.google.com → APIs & Credentials
# ═══════════════════════════════════════════════════════════════

# ─── Frontend (Vite) ─────────────────────────────────────────
# Leave empty to use localhost:8000 in development
VITE_API_URL=https://your-backend.railway.app

# ─── Supabase (Frontend — anon key, безопасно для клиента) ───
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── Google OAuth (для Calendar интеграции) ───────────────────
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Backend (FastAPI) ───────────────────────────────────────
# DATABASE_URL для бэкенда (PostgreSQL через Supabase)
DATABASE_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres

# Supabase Service Role Key (ТОЛЬКО для серверных миграций, НИКОГДА не в клиенте!)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── AI Сервисы ───────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
YANDEX_GPT_KEY=your_yandex_gpt_key_here

# ─── Redis (для Celery) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
