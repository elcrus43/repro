# ═══════════════════════════════════════════════════════════════
# .env.example — шаблон переменных окружения
#
# ❗ НИКОГДА не коммитьте .env в репозиторий!
# ❗ Этот файл (.env.example) коммитить МОЖНО — в нём нет реальных ключей.
#
# Использование:
#   cp .env.example .env
#   Затем заполните реальными значениями из:
#     - Supabase: https://app.supabase.com → Project Settings → API
#     - Google: https://console.cloud.google.com → APIs & Credentials
# ═══════════════════════════════════════════════════════════════

# ─── Backend API (FastAPI) ────────────────────────────────────
# Leave empty to use localhost:8000 in development
VITE_API_URL=https://your-backend.railway.app

# ─── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── Google OAuth (для Calendar интеграции) ───────────────────
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
