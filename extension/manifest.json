{
  "manifest_version": 3,
  "name": "Realtor-Match Importer",
  "version": "1.0",
  "description": "Импорт объектов недвижимости с Авито и ЦИАН",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.avito.ru/*",
    "*://*.cian.ru/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Импорт объекта"
  }
}
